# Environment Variables for School Management System

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (PostgreSQL)
# For Render.com, use DATABASE_URL instead of individual DB variables
DATABASE_URL=postgresql://username:password@hostname:port/database_name

# Alternative individual database variables (for local development)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=mummy
DB_PASSWORD=your_password
DB_PORT=5432

# Session Configuration
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# Encryption Configuration
ENCRYPTION_KEY=your_32_character_encryption_key_here_change_this

# Security Notes:
# - Change all default values in production
# - Use strong, unique passwords and secrets
# - Keep this file secure and never commit actual values to version control