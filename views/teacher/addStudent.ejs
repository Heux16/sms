<%-include ("../partials/header.ejs") %>

<%
// safe fallbacks if server didn't pass data
const classList = (typeof classes !== 'undefined' && Array.isArray(classes)) ? classes : ['Class 6','Class 7','Class 8'];
%>

<!-- Main Content -->
<main class="min-h-screen pt-20 pb-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="glass-effect rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 sm:mb-8 shadow-soft">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex-1 min-w-0">
                    <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent mb-2 sm:mb-3">
                        Add New Student
                    </h1>
                    <p class="text-sm sm:text-base lg:text-lg text-gray-600 flex items-start sm:items-center flex-wrap">
                        <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0 mt-0.5 sm:mt-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                        </svg>
                        <span>Register a new student to your class</span>
                    </p>
                </div>
                <div class="hidden sm:block flex-shrink-0">
                    <div class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20 bg-gradient-to-br from-blue-400 to-indigo-600 rounded-2xl flex items-center justify-center shadow-lg">
                        <svg class="h-7 w-7 sm:h-8 sm:w-8 lg:h-10 lg:w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Student Registration Form -->
        <div class="max-w-4xl mx-auto">
            <form action="/addStudent" method="POST" class="glass-effect rounded-2xl shadow-soft overflow-hidden">
                <!-- Form Header -->
                <div class="bg-gradient-to-r from-accent-50 to-accent-100 px-4 py-3 sm:px-6 sm:py-4 lg:px-8 lg:py-6 border-b border-accent-200">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
                        <div class="h-10 w-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                            </svg>
                        </div>
                        <div class="min-w-0 flex-1">
                            <h3 class="text-base sm:text-lg lg:text-xl font-semibold text-accent-700">Student Information</h3>
                            <p class="text-xs sm:text-sm text-accent-600 mt-1">Enter the student details below to add them to your class</p>
                        </div>
                    </div>
                </div>

                <!-- Form Body -->
                <div class="p-4 sm:p-6 lg:p-8">
                    <div class="space-y-6">
                        <!-- Student Name -->
                        <div class="w-full">
                            <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="username">
                                <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span>Student Full Name *</span>
                            </label>
                            <input 
                                id="username" 
                                name="username" 
                                type="text"
                                required 
                                placeholder="Enter student's full name"
                                class="w-full px-4 py-3 sm:py-4 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200 text-base"
                                autocomplete="name"
                            />
                            <p class="text-xs text-gray-500 mt-2">Enter the complete name as it should appear in records</p>
                        </div>

                        <!-- Mobile-Optimized Two-Column Layout -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
                            <!-- Roll Number -->
                            <div id="rollWrapper">
                                <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="rollNumber">
                                    <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                    </svg>
                                    <span>Roll Number</span>
                                </label>
                                <input 
                                    id="rollNumber" 
                                    name="rollNumber" 
                                    type="text"
                                    placeholder="e.g. 001, A001, 2024001"
                                    class="w-full px-4 py-3 sm:py-4 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200 text-base"
                                    pattern="[A-Za-z0-9]+"
                                    title="Roll number can contain letters and numbers only"
                                />
                                <p class="text-xs text-gray-500 mt-2">Unique identifier for the student</p>
                            </div>

                            <!-- Class Selection -->
                            <div id="classWrapper">
                                <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="classSelect">
                                    <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                    </svg>
                                    <span>Class Assignment *</span>
                                </label>
                                <select 
                                    id="classSelect" 
                                    name="clas" 
                                    required
                                    class="w-full px-4 py-3 sm:py-4 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200 text-base appearance-none bg-no-repeat bg-right"
                                    style="background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; fill=&quot;none&quot; viewBox=&quot;0 0 24 24&quot; stroke=&quot;currentColor&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M19 9l-7 7-7-7&quot;/></svg>'); background-position: right 1rem center; background-size: 1rem;"
                                >
                                    <option value="" disabled selected class="text-gray-500">Select student's class</option>
                                    <% classList.forEach(function(c){ %>
                                        <option value="<%= c %>"><%= c %></option>
                                    <% }) %>
                                </select>
                                <p class="text-xs text-gray-500 mt-2">Assign student to appropriate class level</p>
                            </div>
                        </div>

                        <!-- Additional Student Info -->
                        
                    </div>
                </div>

                <!-- Form Footer -->
                <div class="bg-gray-50/80 backdrop-blur-sm px-4 py-3 sm:px-6 sm:py-4 lg:px-8 lg:py-6 border-t border-gray-200">
                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 sm:justify-end">
                        <button 
                            type="button" 
                            onclick="history.back()" 
                            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 sm:py-4 bg-white border border-gray-300 text-gray-700 font-medium rounded-xl hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500/50 transition-all duration-200 text-base"
                        >
                            <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                            Cancel
                        </button>
                        <button 
                            type="submit" 
                            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 sm:py-4 bg-gradient-to-r from-primary-500 to-accent-600 text-white font-medium rounded-xl hover:from-primary-600 hover:to-accent-700 focus:outline-none focus:ring-2 focus:ring-primary-500/50 transition-all duration-200 shadow-soft hover:shadow-lg transform hover:-translate-y-0.5 text-base"
                        >
                            <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                            </svg>
                            Add Student
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</main>

<%-include ("../partials/footer.ejs") %>
