
<%-include ("../partials/header.ejs") %>

<!-- Main Content -->
<main class="min-h-screen pt-20 pb-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="glass-effect rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 sm:mb-8 shadow-soft">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex-1 min-w-0">
                    <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent mb-2 sm:mb-3">
                        Set Marks
                    </h1>
                    <p class="text-sm sm:text-base lg:text-lg text-gray-600 flex items-start sm:items-center flex-wrap">
                        <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0 mt-0.5 sm:mt-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span><strong><%= exam.exam_name %></strong> - <%= exam.class %></span>
                    </p>
                </div>
                <div class="hidden sm:block flex-shrink-0">
                    <div class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20 bg-gradient-to-br from-orange-400 to-red-600 rounded-2xl flex items-center justify-center shadow-lg">
                        <svg class="h-7 w-7 sm:h-8 sm:w-8 lg:h-10 lg:w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Test Selection -->
        <div class="glass-effect rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 sm:mb-8 shadow-soft">
            <form id="selectTestForm">
                <div class="flex flex-col sm:flex-row sm:items-end gap-4">
                    <div class="flex-1">
                        <label for="testSelect" class="flex items-center text-sm font-semibold text-gray-700 mb-3">
                            <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                            </svg>
                            <span>Choose Test/Subject *</span>
                        </label>
                        <select 
                            id="testSelect" 
                            name="testId" 
                            class="w-full px-4 py-3 sm:py-4 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200 text-base appearance-none bg-no-repeat bg-right"
                            style="background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; fill=&quot;none&quot; viewBox=&quot;0 0 24 24&quot; stroke=&quot;currentColor&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M19 9l-7 7-7-7&quot;/></svg>'); background-position: right 1rem center; background-size: 1rem;"
                        >
                            <option value="" disabled selected>Select a test to grade</option>
                            <% if (typeof tests !== 'undefined' && tests.length) { %>
                                <% tests.forEach(function(t){ %>
                                    <option value="<%= t.testid %>"><%= t.subject %></option>
                                <% }) %>
                            <% } else { %>
                                <option disabled>No tests created for this exam</option>
                            <% } %>
                        </select>
                        <p class="text-xs text-gray-500 mt-2">Select the test subject you want to grade</p>
                    </div>
                    <% if (typeof tests !== 'undefined' && tests.length === 0) { %>
                        <div class="sm:w-auto">
                            <button 
                                type="button" 
                                onclick="window.location.href='/teacher/addTest/<%= exam.examid %>'"
                                class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 sm:py-4 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-medium rounded-xl hover:from-green-600 hover:to-emerald-700 transition-all duration-200 shadow-soft hover:shadow-lg transform hover:-translate-y-0.5 text-base"
                            >
                                <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                                </svg>
                                Create Test
                            </button>
                        </div>
                    <% } %>
                </div>
            </form>
        </div>

        <!-- Marks Entry Form -->
        <div class="glass-effect rounded-2xl p-4 sm:p-6 lg:p-8 shadow-soft">
            <form id="marksForm" action="/teacher/setMarks" method="POST" class="space-y-6">
                <input type="hidden" name="examId" value="<%= exam.examid %>">
                <input type="hidden" name="testId" value="" required>
                
                <!-- Form Header -->
                <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl p-4 mb-6 border border-primary-100">
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-800 flex items-center mb-2">
                        <svg class="h-6 w-6 mr-2 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                        </svg>
                        <span>Student Grades</span>
                    </h3>
                    <p class="text-gray-600 text-sm">Select a test above to enter or view student marks (Max: 100 points each)</p>
                </div>

                <!-- Responsive Table Container -->
                <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white/50 backdrop-blur-sm">
                    <table class="min-w-full">
                        <thead>
                            <tr class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
                                <th class="px-3 sm:px-4 py-3 text-left text-xs sm:text-sm font-semibold text-gray-700 w-12">#</th>
                                <th class="px-3 sm:px-4 py-3 text-left">
                                    <div class="flex items-center text-xs sm:text-sm font-semibold text-gray-700">
                                        <svg class="h-4 w-4 mr-2 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                        Student
                                    </div>
                                </th>
                                <th class="px-3 sm:px-4 py-3 text-left text-xs sm:text-sm font-semibold text-gray-700 hidden sm:table-cell">Roll No.</th>
                                <th class="px-3 sm:px-4 py-3 text-center">
                                    <div class="flex items-center justify-center text-xs sm:text-sm font-semibold text-gray-700">
                                        <svg class="h-4 w-4 mr-1 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                                        </svg>
                                        <span class="hidden sm:inline">Theory</span>
                                        <span class="sm:hidden">Th.</span>
                                    </div>
                                </th>
                                <th class="px-3 sm:px-4 py-3 text-center">
                                    <div class="flex items-center justify-center text-xs sm:text-sm font-semibold text-gray-700">
                                        <svg class="h-4 w-4 mr-1 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 7.172V5L8 4z"/>
                                        </svg>
                                        <span class="hidden sm:inline">Practical</span>
                                        <span class="sm:hidden">Pr.</span>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (typeof students !== 'undefined' && students.length) { %>
                                <% students.forEach(function(student, idx){ %>
                                    <tr data-student-id="<%= student.id %>" data-scores='<%- JSON.stringify(student.scoresMap || {}) %>' class="hover:bg-primary-50/30 transition-colors duration-200">
                                        <td class="px-3 sm:px-4 py-3 text-sm font-medium text-gray-600"><%= idx + 1 %></td>
                                        <td class="px-3 sm:px-4 py-3">
                                            <div class="text-sm font-medium text-gray-800"><%= student.username %></div>
                                            <div class="text-xs text-gray-500 sm:hidden">Roll: <%= student.rollnumber %></div>
                                        </td>
                                        <td class="px-3 sm:px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= student.rollnumber %></td>
                                        <input type="hidden" name="scores[<%= student.id %>][id]" value="<%= student.id %>">
                                        <td class="px-3 sm:px-4 py-3 theory-cell text-center">
                                            <input 
                                                type="number" 
                                                max="100" 
                                                name="scores[<%= student.id %>][score_theory]" 
                                                class="w-16 sm:w-20 px-2 py-1 text-center bg-white/80 backdrop-blur-sm border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-300 transition-all duration-200" 
                                                min="0"
                                                placeholder="0"
                                            >
                                        </td>
                                        <td class="px-3 sm:px-4 py-3 practical-cell text-center">
                                            <input 
                                                type="number" 
                                                max="100" 
                                                name="scores[<%= student.id %>][score_practical]" 
                                                class="w-16 sm:w-20 px-2 py-1 text-center bg-white/80 backdrop-blur-sm border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-green-300 transition-all duration-200" 
                                                min="0"
                                                placeholder="0"
                                            >
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-4 py-12 text-center">
                                        <div class="flex flex-col items-center justify-center">
                                            <svg class="h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                            </svg>
                                            <p class="text-gray-500 text-lg font-medium">No students found for this class</p>
                                            <p class="text-gray-400 text-sm mt-1">Add students to start grading</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Submit Button -->
                <div class="flex flex-col sm:flex-row gap-4 justify-end pt-4">
                    <button 
                        type="button" 
                        onclick="clearAllMarks()"
                        class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-gray-500 to-gray-600 text-white font-medium rounded-xl hover:from-gray-600 hover:to-gray-700 transition-all duration-200 shadow-soft hover:shadow-lg transform hover:-translate-y-0.5 text-base"
                    >
                        <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                        Clear All
                    </button>
                    <button 
                        type="submit" 
                        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-xl hover:from-primary-600 hover:to-primary-700 transition-all duration-200 shadow-soft hover:shadow-lg transform hover:-translate-y-0.5 text-base focus:outline-none focus:ring-2 focus:ring-primary-500/50"
                    >
                        <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Save All Marks
                    </button>
                </div>
            </form>
        </div>
</div>

        <script>
            // Handle test selection and show/hide inputs based on existing scores
            document.getElementById('testSelect').addEventListener('change', function(e) {
                const testId = this.value;
                const marksForm = document.getElementById('marksForm');
                marksForm.querySelector('[name=testId]').value = testId;
                
                // Update each student row
                const rows = document.querySelectorAll('tbody tr[data-student-id]');
                rows.forEach(row => {
                    const studentId = row.getAttribute('data-student-id');
                    const scoresMap = JSON.parse(row.getAttribute('data-scores') || '{}');
                    const theoryCell = row.querySelector('.theory-cell');
                    const practicalCell = row.querySelector('.practical-cell');
                    
                    // Check if student has scores for this test
                    const hasScores = scoresMap[testId];
                    
                    if (hasScores) {
                        // Show existing scores with professional styling
                        theoryCell.innerHTML = `<div class="inline-flex items-center justify-center px-3 py-2 bg-green-100 text-green-800 rounded-lg font-semibold text-sm">
                            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            ${hasScores.score_theory !== null ? hasScores.score_theory : '-'}
                        </div>`;
                        practicalCell.innerHTML = `<div class="inline-flex items-center justify-center px-3 py-2 bg-green-100 text-green-800 rounded-lg font-semibold text-sm">
                            <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            ${hasScores.score_practical !== null ? hasScores.score_practical : '-'}
                        </div>`;
                    } else {
                        // Show input fields with professional styling
                        theoryCell.innerHTML = `<input 
                            type="number" 
                            max="100" 
                            name="scores[${studentId}][score_theory]" 
                            class="w-16 sm:w-20 px-2 py-1 text-center bg-white/80 backdrop-blur-sm border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-300 transition-all duration-200" 
                            required 
                            min="0"
                            placeholder="0"
                        >`;
                        practicalCell.innerHTML = `<input 
                            type="number" 
                            max="100" 
                            name="scores[${studentId}][score_practical]" 
                            class="w-16 sm:w-20 px-2 py-1 text-center bg-white/80 backdrop-blur-sm border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-green-300 transition-all duration-200" 
                            required 
                            min="0"
                            placeholder="0"
                        >`;
                    }
                });
                
                // Add visual feedback
                this.classList.add('ring-2', 'ring-primary-500/50', 'border-primary-300');
                setTimeout(() => {
                    this.classList.remove('ring-2', 'ring-primary-500/50', 'border-primary-300');
                }, 1000);
            });

            // Clear all marks function
            function clearAllMarks() {
                if (confirm('Are you sure you want to clear all entered marks? This action cannot be undone.')) {
                    const inputs = document.querySelectorAll('input[type="number"]');
                    inputs.forEach(input => input.value = '');
                    
                    // Show success message
                    showNotification('All marks cleared successfully!', 'info');
                }
            }

            // Form submission with loading state
            document.getElementById('marksForm').addEventListener('submit', function(e) {
                const submitBtn = this.querySelector('button[type="submit"]');
                const originalHTML = submitBtn.innerHTML;
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.innerHTML = `
                    <svg class="animate-spin h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Saving Marks...
                `;
                
                // Re-enable after 3 seconds (in case form doesn't submit)
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHTML;
                }, 3000);
            });

            // Show notification function
            function showNotification(message, type = 'success') {
                const notification = document.createElement('div');
                notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-xl shadow-lg transform translate-x-full transition-transform duration-300 ${
                    type === 'success' ? 'bg-green-500 text-white' : 
                    type === 'error' ? 'bg-red-500 text-white' : 
                    'bg-blue-500 text-white'
                }`;
                notification.innerHTML = `
                    <div class="flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        ${message}
                    </div>
                `;
                
                document.body.appendChild(notification);
                
                // Show notification
                setTimeout(() => {
                    notification.classList.remove('translate-x-full');
                }, 100);
                
                // Hide notification after 3 seconds
                setTimeout(() => {
                    notification.classList.add('translate-x-full');
                    setTimeout(() => {
                        document.body.removeChild(notification);
                    }, 300);
                }, 3000);
            }

            // Add input validation and auto-formatting
            document.addEventListener('input', function(e) {
                if (e.target.type === 'number' && e.target.hasAttribute('max')) {
                    const value = parseInt(e.target.value);
                    const max = parseInt(e.target.getAttribute('max'));
                    
                    if (value > max) {
                        e.target.value = max;
                        showNotification(`Maximum score is ${max}`, 'error');
                    }
                    
                    // Add visual feedback for valid entries
                    if (value >= 0 && value <= max) {
                        e.target.classList.add('border-green-300', 'bg-green-50');
                        setTimeout(() => {
                            e.target.classList.remove('border-green-300', 'bg-green-50');
                        }, 500);
                    }
                }
            });
        </script>

<%-include ("../partials/footer.ejs") %>
