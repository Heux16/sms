<%-include ("../partials/header.ejs") %>

<main class="flex-1 px-4 py-8">
    <!-- Welcome Section -->
    <div class="mb-8">
        <div class="glass-effect rounded-2xl p-8 shadow-soft">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-accent-800 mb-2">Welcome Back, Student</h1>
                    <p class="text-accent-600">Track your academic progress and stay updated with your courses</p>
                </div>
                <div class="hidden lg:block">
                    <div class="h-16 w-16 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center">
                        <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="glass-effect rounded-xl p-6 shadow-soft">
            <div class="flex items-center">
                <div class="h-12 w-12 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg flex items-center justify-center mr-4">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-accent-600">Total Courses</p>
                    <p class="text-2xl font-bold text-accent-800">8</p>
                </div>
            </div>
        </div>
        
        <div class="glass-effect rounded-xl p-6 shadow-soft">
            <div class="flex items-center">
                <div class="h-12 w-12 bg-gradient-to-br from-green-400 to-green-600 rounded-lg flex items-center justify-center mr-4">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-accent-600">Overall GPA</p>
                    <p class="text-2xl font-bold text-accent-800">3.8</p>
                </div>
            </div>
        </div>
        
        <div class="glass-effect rounded-xl p-6 shadow-soft">
            <div class="flex items-center">
                <div class="h-12 w-12 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center mr-4">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-accent-600">Pending Exams</p>
                    <p class="text-2xl font-bold text-accent-800">3</p>
                </div>
            </div>
        </div>

        <div class="glass-effect rounded-xl p-6 shadow-soft">
            <div class="flex items-center">
                <div class="h-12 w-12 bg-gradient-to-br from-orange-400 to-orange-600 rounded-lg flex items-center justify-center mr-4">
                    <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-medium text-accent-600">Attendance</p>
                    <p class="text-2xl font-bold text-accent-800">94%</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        <!-- Recent Grades -->
        <div class="lg:col-span-2 glass-effect rounded-2xl p-6 shadow-soft">
            <h2 class="text-xl font-bold text-accent-800 mb-6">Recent Grades</h2>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-white/50 rounded-lg border border-accent-100">
                    <div class="flex items-center">
                        <div class="h-10 w-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-white font-bold text-sm">M</span>
                        </div>
                        <div>
                            <h3 class="font-medium text-accent-800">Mathematics</h3>
                            <p class="text-sm text-accent-600">Mid-term Exam</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="text-2xl font-bold text-green-600">A-</span>
                        <p class="text-sm text-accent-500">87/100</p>
                    </div>
                </div>

                <div class="flex items-center justify-between p-4 bg-white/50 rounded-lg border border-accent-100">
                    <div class="flex items-center">
                        <div class="h-10 w-10 bg-gradient-to-br from-green-400 to-green-600 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-white font-bold text-sm">S</span>
                        </div>
                        <div>
                            <h3 class="font-medium text-accent-800">Science</h3>
                            <p class="text-sm text-accent-600">Quiz #3</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="text-2xl font-bold text-green-600">A</span>
                        <p class="text-sm text-accent-500">92/100</p>
                    </div>
                </div>

                <div class="flex items-center justify-between p-4 bg-white/50 rounded-lg border border-accent-100">
                    <div class="flex items-center">
                        <div class="h-10 w-10 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-white font-bold text-sm">E</span>
                        </div>
                        <div>
                            <h3 class="font-medium text-accent-800">English</h3>
                            <p class="text-sm text-accent-600">Essay Assignment</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="text-2xl font-bold text-blue-600">B+</span>
                        <p class="text-sm text-accent-500">85/100</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div class="glass-effect rounded-2xl p-6 shadow-soft">
            <h2 class="text-xl font-bold text-accent-800 mb-6">Upcoming Events</h2>
            <div class="space-y-4">
                <div class="flex items-start space-x-3 p-3 bg-red-50 border border-red-100 rounded-lg">
                    <div class="h-8 w-8 bg-red-500 rounded-lg flex items-center justify-center">
                        <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-medium text-accent-800">Physics Exam</h3>
                        <p class="text-sm text-accent-600">Tomorrow, 10:00 AM</p>
                    </div>
                </div>

                <div class="flex items-start space-x-3 p-3 bg-blue-50 border border-blue-100 rounded-lg">
                    <div class="h-8 w-8 bg-blue-500 rounded-lg flex items-center justify-center">
                        <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-medium text-accent-800">History Assignment</h3>
                        <p class="text-sm text-accent-600">Due: March 15</p>
                    </div>
                </div>

                <div class="flex items-start space-x-3 p-3 bg-green-50 border border-green-100 rounded-lg">
                    <div class="h-8 w-8 bg-green-500 rounded-lg flex items-center justify-center">
                        <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-medium text-accent-800">Parent-Teacher Meet</h3>
                        <p class="text-sm text-accent-600">March 20, 2:00 PM</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="glass-effect rounded-2xl p-8 shadow-soft">
        <h2 class="text-2xl font-bold text-accent-800 mb-6">Quick Actions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <button class="flex items-center justify-center px-6 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-xl hover:from-blue-600 hover:to-blue-700 transition-all duration-200 transform hover:-translate-y-0.5 shadow-soft">
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                View Grades
            </button>
            
            <button class="flex items-center justify-center px-6 py-4 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-200 transform hover:-translate-y-0.5 shadow-soft">
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                View Schedule
            </button>
            
            <button class="flex items-center justify-center px-6 py-4 bg-gradient-to-r from-purple-500 to-purple-600 text-white rounded-xl hover:from-purple-600 hover:to-purple-700 transition-all duration-200 transform hover:-translate-y-0.5 shadow-soft">
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Assignments
            </button>
            
            <button class="flex items-center justify-center px-6 py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-white rounded-xl hover:from-orange-600 hover:to-orange-700 transition-all duration-200 transform hover:-translate-y-0.5 shadow-soft">
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                Messages
            </button>
        </div>
    </div>
</main>

<%-include ("../partials/footer.ejs") %>