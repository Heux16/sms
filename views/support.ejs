                        <div class="p-6 space-y-4">
                            <!-- FAQ Item 1 -->
                            <div class="faq-item border border-gray-200 rounded-xl">
                                <button class="w-full p-4 text-left flex items-center justify-between hover:bg-gray-50 transition-colors duration-200" onclick="toggleFaq(this)">
                                    <h3 class="font-semibold text-gray-800">How do I reset my password?</h3>
                                    <div class="faq-toggle w-6 h-6 border-2 border-primary-500 rounded-full flex items-center justify-center transition-transform duration-200">
                                        <svg class="w-3 h-3 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                                        </svg>
                                    </div>
                                </button>
                                <div class="faq-content">
                                    <div class="px-4 pb-4">
                                        <p class="text-gray-600 text-sm mb-3">Contact your system administrator or school IT department to reset your password. You'll need to provide:</p>
                                        <ul class="text-gray-600 text-sm space-y-1 ml-4">
                                            <li>• Your full name</li>
                                            <li>• Student/Employee ID</li>
                                            <li>• Alternative email address</li>
                                            <li>• Reason for reset request</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- FAQ Item 2 -->
