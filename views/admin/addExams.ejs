<%-include ("../partials/header.ejs") %>

<%
// safe fallbacks if server didn't pass data
const classList = (typeof classes !== 'undefined' && Array.isArray(classes)) ? classes : ['Class 6','Class 7','Class 8'];
%>

<!-- Main Content -->
<main class="min-h-screen pt-20 pb-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="glass-effect rounded-2xl p-6 sm:p-8 mb-8 shadow-soft">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex-1">
                    <h1 class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent mb-2 sm:mb-3">
                        Add New Exam
                    </h1>
                    <p class="text-base sm:text-lg text-gray-600 flex items-center flex-wrap">
                        <svg class="h-5 w-5 mr-2 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span>Create a new examination for students</span>
                    </p>
                </div>
                <div class="hidden sm:block flex-shrink-0">
                    <div class="h-16 w-16 sm:h-20 sm:w-20 bg-gradient-to-br from-purple-400 to-blue-600 rounded-2xl flex items-center justify-center shadow-lg">
                        <svg class="h-8 w-8 sm:h-10 sm:w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Exam Form -->
        <div class="max-w-4xl mx-auto">
            <form action="/addExams" method="POST" class="glass-effect rounded-2xl shadow-soft overflow-hidden">
                <!-- Form Header -->
                <div class="bg-gradient-to-r from-accent-50 to-accent-100 px-6 py-4 sm:px-8 sm:py-6 border-b border-accent-200">
                    <div class="flex items-center">
                        <div class="h-10 w-10 bg-gradient-to-br from-purple-500 to-blue-600 rounded-xl flex items-center justify-center mr-4">
                            <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg sm:text-xl font-semibold text-accent-700">Exam Details</h3>
                            <p class="text-sm text-accent-600">Fill in the information below to create a new exam</p>
                        </div>
                    </div>
                </div>

                <!-- Form Body -->
                <div class="p-6 sm:p-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Exam Name -->
                        <div class="md:col-span-2">
                            <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="exam_name">
                                <svg class="h-5 w-5 mr-2 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                                Exam Name *
                            </label>
                            <input 
                                id="exam_name" 
                                name="exam_name" 
                                type="text"
                                required 
                                placeholder="Enter exam name (e.g., Mid-term Mathematics Exam)"
                                class="w-full px-4 py-3 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200"
                            />
                        </div>

                        <!-- Class Selection -->
                        <div>
                            <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="class">
                                <svg class="h-5 w-5 mr-2 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                </svg>
                                Class *
                            </label>
                            <select 
                                id="class" 
                                name="examClass" 
                                required 
                                class="w-full px-4 py-3 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200"
                            >
                                <option value="" disabled selected class="text-gray-500">Select a class</option>
                                <% classList.forEach(function(c){ %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Test Type -->
                        <div>
                            <label class="flex items-center text-sm font-semibold text-gray-700 mb-3" for="testtype">
                                <svg class="h-5 w-5 mr-2 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                </svg>
                                Test Type *
                            </label>
                            <select 
                                id="testtype" 
                                name="testtype" 
                                required 
                                class="w-full px-4 py-3 bg-white/80 backdrop-blur-sm border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-300 transition-all duration-200"
                            >
                                <option value="" disabled selected class="text-gray-500">Select test type</option>
                                <option value="monthly">Monthly Assessment</option>
                                <option value="quarterly">Quarterly Examination</option>
                                
                            </select>
                        </div>

                        <!-- Publication Status -->
                        <div class="md:col-span-2">
                            <label class="flex items-center text-sm font-semibold text-gray-700 mb-3">
                                <svg class="h-5 w-5 mr-2 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
                                </svg>
                                Publication Status *
                            </label>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <label class="relative">
                                    <input 
                                        type="radio" 
                                        name="is_published" 
                                        value="false" 
                                        checked 
                                        class="peer sr-only"
                                    />
                                    <div class="flex items-center p-4 bg-white/60 backdrop-blur-sm border-2 border-gray-200 rounded-xl cursor-pointer hover:border-orange-300 peer-checked:border-orange-500 peer-checked:bg-orange-50 transition-all duration-200">
                                        <div class="flex-shrink-0 h-8 w-8 bg-gradient-to-br from-orange-100 to-yellow-100 rounded-lg flex items-center justify-center mr-3">
                                            <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-900">Save as Draft</div>
                                            <div class="text-sm text-gray-600">Keep exam private for now</div>
                                        </div>
                                    </div>
                                </label>
                                <label class="relative">
                                    <input 
                                        type="radio" 
                                        name="is_published" 
                                        value="true" 
                                        class="peer sr-only"
                                    />
                                    <div class="flex items-center p-4 bg-white/60 backdrop-blur-sm border-2 border-gray-200 rounded-xl cursor-pointer hover:border-green-300 peer-checked:border-green-500 peer-checked:bg-green-50 transition-all duration-200">
                                        <div class="flex-shrink-0 h-8 w-8 bg-gradient-to-br from-green-100 to-emerald-100 rounded-lg flex items-center justify-center mr-3">
                                            <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-900">Publish Immediately</div>
                                            <div class="text-sm text-gray-600">Make exam available to students</div>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Footer -->
                <div class="bg-gray-50/80 backdrop-blur-sm px-6 py-4 sm:px-8 sm:py-6 border-t border-gray-200">
                    <div class="flex flex-col sm:flex-row gap-4 sm:justify-end">
                        <button 
                            type="button" 
                            onclick="history.back()" 
                            class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 bg-white border border-gray-300 text-gray-700 font-medium rounded-xl hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500/50 transition-all duration-200"
                        >
                            <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                            Cancel
                        </button>
                        <button 
                            type="submit" 
                            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 bg-gradient-to-r from-primary-500 to-accent-600 text-white font-medium rounded-xl hover:from-primary-600 hover:to-accent-700 focus:outline-none focus:ring-2 focus:ring-primary-500/50 transition-all duration-200 shadow-soft hover:shadow-lg transform hover:-translate-y-0.5"
                        >
                            <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Create Exam
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</main>

<%-include ("../partials/footer.ejs") %>